# ==========================================
# AUTHENTICATION & JWT
# ==========================================
JWT_SECRET_KEY="tu_super_secreto_para_jwt_aqui"
ACCESS_TOKEN_EXPIRE_MINUTES=3000000
REFRESH_TOKEN_EXPIRE_DAYS=3000
ADMIN_SECRET_KEY="admin_secret_opcional"

# ==========================================
# MONGODB CONFIGURATION
# ==========================================
MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="mi_base_de_datos"

# ==========================================
# SUPABASE (VECTOR STORE)
# ==========================================
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_KEY="tu_service_role_key_aqui"
SUPABASE_TABLE_NAME="default_collection"

# ==========================================
# AI & LLM PROVIDERS
# ==========================================
GEMINI_API_KEY="tu_api_key_de_google_gemini"
MISTRAL_API_KEY="tu_api_key_de_mistral_para_ocr"
# OCR backend: true = Mistral OCR, false = Gemini Vision (default)
USE_MISTRAL_OCR=false

# ==========================================
# SYSTEM/DOCKER CONFIGURATION
# ==========================================
ENVIRONMENT="development"
UPLOAD_FOLDER="/app/uploads"
TEMP_FOLDER="/app/temp"
